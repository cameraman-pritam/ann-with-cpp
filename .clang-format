---
# Start with a clean, standardized base
BasedOnStyle: Google

# --- SPACING & INDENTATION ---
# 2 spaces for indentation (Standard C++ practice). No tabs.
IndentWidth: 2
TabWidth: 2
UseTab: Never

# Line length. Python's "Black" formatter uses 88, which is great for readability.
ColumnLimit: 88

# --- VERTICAL BREATHING ROOM (No cramped code) ---
# These rules disable C++ "one-liners" so everything expands into clear blocks.
# Even with 2-space indents, this keeps your control flow easy to read.
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false

# Keep up to 2 empty lines to separate logical chunks of math/logic
MaxEmptyLinesToKeep: 2
KeepEmptyLinesAtTheStartOfBlocks: false

# --- BRACKET PLACEMENT ---
# 'Attach' keeps the opening brace on the same line.
BreakBeforeBraces: Attach

# --- CLEAN ALIGNMENT FOR MATH & VARIABLES ---
# This aligns consecutive variable assignments beautifully,
# which is highly readable for Neural Network weights/biases initialization.
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: true
AlignOperands: Align

# --- PRECISE SPACING ---
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements
SpaceInEmptyParentheses: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpaceAfterCStyleCast: true

# Indent switch statements properly
IndentCaseLabels: true
...
